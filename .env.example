# Flask / app
FLASK_SECRET_KEY=change-me-to-a-long-random-secret
HOST=0.0.0.0
PORT=8080
FLASK_DEBUG=false

# DNS configuration
DNS_ZONE=example.com
DNS_SERVER=dc01.example.com
ALLOWED_ADMIN_GROUP=DNS-Admins
DNS_EXECUTION_MODE=local

# OIDC / SSO
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration
OIDC_REDIRECT_URI=https://dns-manager.example.com/auth/callback
OIDC_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_post

# Proxy / cookies
TRUST_PROXY=1
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax

# Remote PowerShell / WinRM
POWERSHELL_EXE=pwsh
WINRM_AUTH=Kerberos
WINRM_USE_SSL=false
WINRM_USERNAME=dns-web-svc
WINRM_PASSWORD=
WINRM_PASSWORD_FILE=/run/secrets/winrm-password
WINRM_DOMAIN=CONTOSO
PWSH_REMOTE_TRANSPORT=wsman
PWSH_SSH_PORT=22
PWSH_SSH_KEY_FILE=
SSH_EXE=ssh

# Cache tuning
DNS_CACHE_DB_PATH=/tmp/ad-dns-web-dns-cache.sqlite3
DNS_CACHE_REFRESH_SECONDS=900
DNS_TREE_CACHE_TTL=20
RECORDS_CACHE_TTL=10
OAUTH_STATE_DIR=/tmp/ad-dns-web-oauth-state
